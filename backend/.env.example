MONGO_URI=mongodb+srv://<db_user>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
port=4000
# Puerto del backend
PORT=4000

# MongoDB
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority

# Access token
JWT_SECRET=change-me-access-secret
JWT_EXPIRES_IN=15m

# Refresh token
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Credenciales de usuarios seed
ADMIN_USERNAME=admin
ADMIN_PASSWORD=SweetLab@2026!

# Bloqueo de intentos de login
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15
